{
  "created_at": "2026-04-07T22:35:16.364542313+02:00",
  "description": "A minimal auth service with register and login flows. Users sign up with email and password, receive a JWT access token on success, and can access protected resources. The frontend is a Next.js app with React Hook Form + Zod validation calling the Go/Fiber backend over REST.",
  "data": {
    "databases": [
      {
        "alias": "primary",
        "type": "PostgreSQL",
        "ssl_mode": "require",
        "replication": "single-node"
      }
    ],
    "domains": [
      {
        "name": "User",
        "description": "Authenticated system user",
        "databases": "primary",
        "attributes": [
          {
            "name": "id",
            "type": "UUID",
            "constraints": "Primary Key, Auto-generated"
          },
          {
            "name": "email",
            "type": "String",
            "constraints": "Required, Unique",
            "validation": "valid email format"
          },
          {
            "name": "password_hash",
            "type": "String",
            "constraints": "Required"
          },
          {
            "name": "is_active",
            "type": "Boolean",
            "constraints": "Required",
            "default": "true"
          },
          {
            "name": "refresh_token",
            "type": "String",
            "constraints": "Nullable"
          },
          {
            "name": "refresh_token_expires_at",
            "type": "DateTime",
            "constraints": "Nullable"
          },
          {
            "name": "created_at",
            "type": "DateTime",
            "constraints": "Required, Auto-generated"
          },
          {
            "name": "updated_at",
            "type": "DateTime",
            "constraints": "Required, Auto-updated"
          }
        ]
      }
    ]
  },
  "backend": {
    "arch_pattern": "monolith",
    "services": [
      {
        "name": "auth-api",
        "responsibility": "Handles user registration, login, token refresh, and logout",
        "technologies": [
          "REST"
        ],
        "health_deps": [
          "primary"
        ],
        "repositories": [
          {
            "name": "UserRepository",
            "entity_ref": "User",
            "target_db": "primary",
            "operations": [
              {
                "name": "FindByEmail",
                "op_type": "query",
                "filter_by": [
                  "email"
                ],
                "result_shape": "Single item"
              },
              {
                "name": "FindByID",
                "op_type": "query",
                "filter_by": [
                  "id"
                ],
                "result_shape": "Single item"
              },
              {
                "name": "Create",
                "op_type": "insert",
                "result_shape": "Single item"
              },
              {
                "name": "UpdateRefreshToken",
                "op_type": "update",
                "filter_by": [
                  "id"
                ],
                "description": "Update refresh_token and refresh_token_expires_at for a user"
              },
              {
                "name": "ClearRefreshToken",
                "op_type": "update",
                "filter_by": [
                  "id"
                ],
                "description": "Nullify refresh_token and refresh_token_expires_at on logout"
              }
            ]
          }
        ]
      }
    ],
    "auth": {
      "provider": "self-managed",
      "service_unit": "auth-api",
      "authz_model": "RBAC",
      "permissions": [
        {
          "name": "profile:read",
          "description": "Read own profile"
        },
        {
          "name": "profile:update",
          "description": "Update own profile"
        }
      ],
      "roles": [
        {
          "name": "user",
          "description": "Authenticated end user",
          "permissions": [
            "profile:read",
            "profile:update"
          ]
        }
      ]
    },
    "language": "Go",
    "language_version": "1.24",
    "framework": "Fiber",
    "framework_version": "v3.0"
  },
  "contracts": {
    "dtos": [
      {
        "name": "RegisterRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for user registration",
        "protocol": "REST/JSON",
        "fields": [
          {
            "name": "email",
            "type": "string",
            "required": true,
            "validation": "valid email format"
          },
          {
            "name": "password",
            "type": "string",
            "required": true,
            "validation": "min 8 chars, at least one number"
          },
          {
            "name": "confirm_password",
            "type": "string",
            "required": true,
            "validation": "must match password"
          }
        ]
      },
      {
        "name": "LoginRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for user login",
        "protocol": "REST/JSON",
        "fields": [
          {
            "name": "email",
            "type": "string",
            "required": true,
            "validation": "valid email format"
          },
          {
            "name": "password",
            "type": "string",
            "required": true
          }
        ]
      },
      {
        "name": "RefreshTokenRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for refreshing an access token (sent as HttpOnly cookie; no body required)",
        "protocol": "REST/JSON"
      },
      {
        "name": "AuthTokenResponse",
        "category": "Response",
        "source_domains": "User",
        "description": "JWT credentials returned after successful register or login",
        "protocol": "REST/JSON",
        "fields": [
          {
            "name": "access_token",
            "type": "string",
            "required": true,
            "notes": "Signed JWT; short-lived (15 min)"
          },
          {
            "name": "token_type",
            "type": "string",
            "required": true,
            "default": "Bearer"
          },
          {
            "name": "expires_in",
            "type": "integer",
            "required": true,
            "notes": "Seconds until access_token expires"
          },
          {
            "name": "refresh_token",
            "type": "string",
            "nullable": true,
            "notes": "Rotated on each use; set as HttpOnly cookie"
          }
        ]
      },
      {
        "name": "UserResponse",
        "category": "Response",
        "source_domains": "User",
        "description": "Public user profile returned from /me",
        "protocol": "REST/JSON",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true,
            "notes": "UUID"
          },
          {
            "name": "email",
            "type": "string",
            "required": true
          },
          {
            "name": "is_active",
            "type": "boolean",
            "required": true
          },
          {
            "name": "created_at",
            "type": "string",
            "required": true,
            "notes": "ISO 8601 timestamp"
          }
        ]
      },
      {
        "name": "ErrorResponse",
        "category": "Response",
        "description": "Standard error envelope for all 4xx/5xx responses",
        "protocol": "REST/JSON",
        "fields": [
          {
            "name": "error",
            "type": "string",
            "required": true,
            "notes": "Machine-readable error code"
          },
          {
            "name": "message",
            "type": "string",
            "required": true,
            "notes": "Human-readable description"
          }
        ]
      }
    ],
    "endpoints": [
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/register",
        "protocol": "REST",
        "auth_required": "No",
        "request_dto": "RegisterRequest",
        "response_dto": "AuthTokenResponse",
        "http_method": "POST",
        "description": "Create a new user account and return JWT credentials",
        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/login",
        "protocol": "REST",
        "auth_required": "No",
        "request_dto": "LoginRequest",
        "response_dto": "AuthTokenResponse",
        "http_method": "POST",
        "description": "Validate credentials and return JWT credentials",
        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/refresh",
        "protocol": "REST",
        "auth_required": "No",
        "request_dto": "RefreshTokenRequest",
        "response_dto": "AuthTokenResponse",
        "http_method": "POST",
        "description": "Issue a new access token using the refresh token cookie"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/logout",
        "protocol": "REST",
        "auth_required": "Yes",
        "auth_roles": "user",
        "response_dto": "ErrorResponse",
        "http_method": "POST",
        "description": "Invalidate the refresh token and clear the auth cookie"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/me",
        "protocol": "REST",
        "auth_required": "Yes",
        "auth_roles": "user",
        "response_dto": "UserResponse",
        "http_method": "GET",
        "description": "Return the profile of the currently authenticated user"
      }
    ],
    "versioning": {
      "per_protocol_strategies": {
        "REST": "URL path (/v1/)"
      },
      "current_version": "v1"
    }
  },
  "frontend": {
    "tech": {
      "language": "TypeScript",
      "language_version": "5.7",
      "platform": "Web (SPA)",
      "framework": "React",
      "framework_version": "19",
      "meta_framework": "Next.js",
      "package_manager": "npm",
      "styling": "Tailwind CSS",
      "component_lib": "shadcn/ui",
      "state_management": "Zustand",
      "data_fetching": "TanStack Query",
      "form_handling": "React Hook Form",
      "validation": "Zod",
      "image_optimization": "Next/Image (built-in)",
      "auth_flow_type": "Redirect (OAuth/OIDC)",
      "error_boundary": "React Error Boundary",
      "bundle_optimization": "Code splitting (route-based)"
    },
    "components": [
      {
        "name": "RegisterForm",
        "component_type": "Form",
        "connected_endpoints": "/api/v1/auth/register",
        "actions": [
          {
            "trigger": "onSubmit",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/register",
            "http_method": "POST",
            "request_body": "RegisterRequest",
            "success_action": "Store token in auth state; navigate to /dashboard",
            "error_action": "Show inline validation errors or server error toast"
          }
        ],
        "description": "Email + password + confirm-password form with Zod validation"
      },
      {
        "name": "LoginForm",
        "component_type": "Form",
        "connected_endpoints": "/api/v1/auth/login",
        "actions": [
          {
            "trigger": "onSubmit",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/login",
            "http_method": "POST",
            "request_body": "LoginRequest",
            "success_action": "Store token in auth state; navigate to /dashboard",
            "error_action": "Show inline validation errors or server error toast"
          }
        ],
        "description": "Email + password form with Zod validation"
      },
      {
        "name": "UserProfileCard",
        "component_type": "Display",
        "connected_endpoints": "/api/v1/auth/me",
        "actions": [
          {
            "trigger": "onMount",
            "action_type": "Fetch Data",
            "endpoint": "/api/v1/auth/me",
            "http_method": "GET",
            "success_action": "Render user email and created_at",
            "error_action": "Redirect to /login on 401"
          }
        ],
        "description": "Shows current user email and account info fetched from /me"
      },
      {
        "name": "LogoutButton",
        "component_type": "Button",
        "connected_endpoints": "/api/v1/auth/logout",
        "actions": [
          {
            "trigger": "onClick",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/logout",
            "http_method": "POST",
            "success_action": "Clear auth state; navigate to /login",
            "error_action": "Show error toast; clear local auth state anyway"
          }
        ],
        "description": "Calls logout endpoint and clears client auth state"
      }
    ],
    "pages": [
      {
        "name": "Register",
        "route": "/register",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit registration form; redirect to /dashboard on success",
        "loading": "Spinner on submit button",
        "error_handling": "Inline field errors (Zod) and toast on server error",
        "linked_pages": "/login,/dashboard"
      },
      {
        "name": "Login",
        "route": "/login",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit login credentials; redirect to /dashboard on success; navigate to /register",
        "loading": "Spinner on submit button",
        "error_handling": "Inline field errors (Zod) and toast on server error",
        "linked_pages": "/register,/dashboard"
      },
      {
        "name": "Dashboard",
        "route": "/dashboard",
        "auth_required": "Yes",
        "layout": "AppLayout",
        "core_actions": "Display user profile from /me; logout button",
        "loading": "Skeleton while fetching profile",
        "error_handling": "Redirect to /login on 401",
        "linked_pages": "/login"
      }
    ],
    "navigation": {
      "nav_type": "Top bar",
      "auth_aware": true
    },
    "rendering": "SSR",
    "framework": "React",
    "styling": "Tailwind CSS"
  },
  "infrastructure": {
    "cicd": {
      "platform": "GitHub Actions",
      "container_registry": "GHCR",
      "deploy_strategy": "Rolling",
