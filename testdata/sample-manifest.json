{
  "created_at": "2026-04-04T12:00:00Z",
  "description": "A minimal auth service with register and login flows. Users sign up with email and password, receive a JWT access token on success, and can access protected resources. The frontend is a Next.js app with React Hook Form + Zod validation calling the Go/Fiber backend over REST.",
  "data": {
    "databases": [
      {
        "alias": "primary",
        "type": "PostgreSQL",
        "is_cache": false
      }
    ],
    "domains": [
      {
        "name": "User",
        "description": "Authenticated system user",
        "databases": "primary",
        "attributes": [
          {"name": "id",                       "type": "UUID",     "constraints": "Primary Key, Auto-generated"},
          {"name": "email",                    "type": "String",   "constraints": "Required, Unique", "validation": "valid email format"},
          {"name": "password_hash",            "type": "String",   "constraints": "Required"},
          {"name": "is_active",                "type": "Boolean",  "constraints": "Required", "default": "true"},
          {"name": "refresh_token",            "type": "String",   "constraints": "Nullable"},
          {"name": "refresh_token_expires_at", "type": "DateTime", "constraints": "Nullable"},
          {"name": "created_at",               "type": "DateTime", "constraints": "Required, Auto-generated"},
          {"name": "updated_at",               "type": "DateTime", "constraints": "Required, Auto-updated"}
        ]
      }
    ],
    "caching": {
      "layer": "None",
      "strategy": "None",
      "invalidation": "None"
    }
  },
  "backend": {
    "arch_pattern": "monolith",
    "env": {
      "stages": "development,production"
    },
    "services": [
      {
        "name": "auth-api",
        "responsibility": "Handles user registration, login, token refresh, and logout",
        "language": "Go",
        "framework": "Fiber",
        "interfaces": [
          {"name": "REST API", "type": "REST", "description": "Auth endpoints consumed by the Next.js frontend"}
        ]
      }
    ],
    "auth": {
      "strategy": "JWT",
      "provider": "self-managed",
      "service_unit": "auth-api",
      "authz_model": "RBAC",
      "token_storage": "HttpOnly cookie",
      "refresh_token": "Enabled",
      "mfa": "None",
      "roles": [
        {
          "name": "user",
          "description": "Authenticated end user",
          "permissions": ["profile:read", "profile:update"]
        }
      ],
      "permissions": [
        {"name": "profile:read",   "description": "Read own profile"},
        {"name": "profile:update", "description": "Update own profile"}
      ]
    }
  },
  "contracts": {
    "dtos": [
      {
        "name": "RegisterRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for user registration",
        "protocol": "REST/JSON",
        "fields": [
          {"name": "email",            "type": "string",  "required": true,  "nullable": false, "validation": "valid email format"},
          {"name": "password",         "type": "string",  "required": true,  "nullable": false, "validation": "min 8 chars, at least one number"},
          {"name": "confirm_password", "type": "string",  "required": true,  "nullable": false, "validation": "must match password"}
        ]
      },
      {
        "name": "LoginRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for user login",
        "protocol": "REST/JSON",
        "fields": [
          {"name": "email",    "type": "string", "required": true, "nullable": false, "validation": "valid email format"},
          {"name": "password", "type": "string", "required": true, "nullable": false}
        ]
      },
      {
        "name": "RefreshTokenRequest",
        "category": "Request",
        "source_domains": "User",
        "description": "Payload for refreshing an access token (sent as HttpOnly cookie; no body required)",
        "protocol": "REST/JSON",
        "fields": []
      },
      {
        "name": "AuthTokenResponse",
        "category": "Response",
        "source_domains": "User",
        "description": "JWT credentials returned after successful register or login",
        "protocol": "REST/JSON",
        "fields": [
          {"name": "access_token",  "type": "string",  "required": true,  "nullable": false, "notes": "Signed JWT; short-lived (15 min)"},
          {"name": "token_type",    "type": "string",  "required": true,  "nullable": false, "default": "Bearer"},
          {"name": "expires_in",    "type": "integer", "required": true,  "nullable": false, "notes": "Seconds until access_token expires"},
          {"name": "refresh_token", "type": "string",  "required": false, "nullable": true,  "notes": "Rotated on each use; set as HttpOnly cookie"}
        ]
      },
      {
        "name": "UserResponse",
        "category": "Response",
        "source_domains": "User",
        "description": "Public user profile returned from /me",
        "protocol": "REST/JSON",
        "fields": [
          {"name": "id",         "type": "string",   "required": true, "nullable": false, "notes": "UUID"},
          {"name": "email",      "type": "string",   "required": true, "nullable": false},
          {"name": "is_active",  "type": "boolean",  "required": true, "nullable": false},
          {"name": "created_at", "type": "string",   "required": true, "nullable": false, "notes": "ISO 8601 timestamp"}
        ]
      },
      {
        "name": "ErrorResponse",
        "category": "Response",
        "description": "Standard error envelope for all 4xx/5xx responses",
        "protocol": "REST/JSON",
        "fields": [
          {"name": "error",   "type": "string", "required": true, "nullable": false, "notes": "Machine-readable error code"},
          {"name": "message", "type": "string", "required": true, "nullable": false, "notes": "Human-readable description"}
        ]
      }
    ],
    "endpoints": [
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/register",
        "protocol": "REST",
        "auth_required": "No",
        "http_method": "POST",
        "request_dto": "RegisterRequest",
        "response_dto": "AuthTokenResponse",
        "description": "Create a new user account and return JWT credentials",
        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/login",
        "protocol": "REST",
        "auth_required": "No",
        "http_method": "POST",
        "request_dto": "LoginRequest",
        "response_dto": "AuthTokenResponse",
        "description": "Validate credentials and return JWT credentials",
        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/refresh",
        "protocol": "REST",
        "auth_required": "No",
        "http_method": "POST",
        "request_dto": "RefreshTokenRequest",
        "response_dto": "AuthTokenResponse",
        "description": "Issue a new access token using the refresh token cookie"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/logout",
        "protocol": "REST",
        "auth_required": "Yes",
        "auth_roles": "user",
        "http_method": "POST",
        "response_dto": "ErrorResponse",
        "description": "Invalidate the refresh token and clear the auth cookie"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/me",
        "protocol": "REST",
        "auth_required": "Yes",
        "auth_roles": "user",
        "http_method": "GET",
        "response_dto": "UserResponse",
        "description": "Return the profile of the currently authenticated user"
      }
    ],
    "versioning": {
      "per_protocol_strategies": {
        "REST": "URL path (/v1/)"
      },
      "current_version": "v1",
      "deprecation_policy": "6-month notice with Sunset header"
    }
  },
  "frontend": {
    "tech": {
      "language": "TypeScript",
      "platform": "Web",
      "framework": "React",
      "meta_framework": "Next.js",
      "package_manager": "npm",
      "styling": "Tailwind CSS",
      "state_management": "Zustand",
      "data_fetching": "TanStack Query",
      "form_handling": "React Hook Form",
      "validation": "Zod",
      "auth_flow_type": "JWT / HttpOnly cookie",
      "error_boundary": "React Error Boundary"
    },
    "pages": [
      {
        "name": "Register",
        "route": "/register",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit registration form; redirect to /dashboard on success",
        "loading": "Spinner on submit button",
        "error_handling": "Inline field errors (Zod) and toast on server error",
        "linked_pages": "/login,/dashboard"
      },
      {
        "name": "Login",
        "route": "/login",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit login credentials; redirect to /dashboard on success; navigate to /register",
        "loading": "Spinner on submit button",
        "error_handling": "Inline field errors (Zod) and toast on server error",
        "linked_pages": "/register,/dashboard"
      },
      {
        "name": "Dashboard",
        "route": "/dashboard",
        "auth_required": "Yes",
        "auth_roles": "user",
        "layout": "AppLayout",
        "core_actions": "Display user profile from /me; logout button",
        "loading": "Skeleton while fetching profile",
        "error_handling": "Redirect to /login on 401",
        "linked_pages": "/login"
      }
    ],
    "components": [
      {
        "name": "RegisterForm",
        "component_type": "Form",
        "connected_endpoints": "/api/v1/auth/register",
        "description": "Email + password + confirm-password form with Zod validation",
        "actions": [
          {
            "trigger": "onSubmit",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/register",
            "http_method": "POST",
            "request_body": "RegisterRequest",
            "success_action": "Store token in auth state; navigate to /dashboard",
            "error_action": "Show inline validation errors or server error toast"
          }
        ]
      },
      {
        "name": "LoginForm",
        "component_type": "Form",
        "connected_endpoints": "/api/v1/auth/login",
        "description": "Email + password form with Zod validation",
        "actions": [
          {
            "trigger": "onSubmit",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/login",
            "http_method": "POST",
            "request_body": "LoginRequest",
            "success_action": "Store token in auth state; navigate to /dashboard",
            "error_action": "Show inline validation errors or server error toast"
          }
        ]
      },
      {
        "name": "UserProfileCard",
        "component_type": "Display",
        "connected_endpoints": "/api/v1/auth/me",
        "description": "Shows current user email and account info fetched from /me",
        "actions": [
          {
            "trigger": "onMount",
            "action_type": "Fetch Data",
            "endpoint": "/api/v1/auth/me",
            "http_method": "GET",
            "success_action": "Render user email and created_at",
            "error_action": "Redirect to /login on 401"
          }
        ]
      },
      {
        "name": "LogoutButton",
        "component_type": "Button",
        "connected_endpoints": "/api/v1/auth/logout",
        "description": "Calls logout endpoint and clears client auth state",
        "actions": [
          {
            "trigger": "onClick",
            "action_type": "Submit Form",
            "endpoint": "/api/v1/auth/logout",
            "http_method": "POST",
            "success_action": "Clear auth state; navigate to /login",
            "error_action": "Show error toast; clear local auth state anyway"
          }
        ]
      }
    ],
    "navigation": {
      "nav_type": "Top bar",
      "breadcrumbs": false,
      "auth_aware": true
    }
  }
}
