          },
          {
            "name": "refresh_token",
            "type": "string",
            "required": false,
            "nullable": true,
            "notes": "Rotated on each use; set as HttpOnly cookie"
          }
        ]
      },
      {
        "name": "UserResponse",
        "category": "Response",
