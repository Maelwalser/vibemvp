        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/login",
        "protocol": "REST",
        "auth_required": "No",
        "request_dto": "LoginRequest",
        "response_dto": "AuthTokenResponse",
        "http_method": "POST",
        "description": "Validate credentials and return JWT credentials",
        "rate_limit": "10 req/min per IP"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/refresh",
        "protocol": "REST",
        "auth_required": "No",
        "request_dto": "RefreshTokenRequest",
        "response_dto": "AuthTokenResponse",
        "http_method": "POST",
