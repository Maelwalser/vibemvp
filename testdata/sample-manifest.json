{
  "created_at": "2026-04-04T12:00:00Z",
  "data": {
    "databases": [
      {
        "alias": "primary",
        "type": "PostgreSQL",
        "is_cache": false
      }
    ],
    "domains": [
      {
        "name": "User",
        "description": "System users requiring authentication",
        "databases": "primary",
        "attributes": [
          {"name": "id", "type": "UUID", "constraints": "Primary Key, Auto-generated"},
          {"name": "email", "type": "String", "constraints": "Required, Unique"},
          {"name": "password_hash", "type": "String", "constraints": "Required"}
        ]
      }
    ],
    "caching": {
      "layer": "None",
      "strategy": "None",
      "invalidation": "None"
    }
  },
  "backend": {
    "arch_pattern": "monolith",
    "env": {
      "compute_env": "containerized",
      "cloud_provider": "Local",
      "orchestrator": "Docker Compose"
    },
    "services": [
      {
        "name": "auth-api",
        "responsibility": "Handles user registration and login",
        "language": "Go",
        "framework": "Fiber",
        "interfaces": [
          {"name": "REST API", "type": "REST"}
        ]
      }
    ],
    "auth": {
      "strategy": "JWT",
      "provider": "self-managed",
      "authz_model": "None",
      "token_storage": "HttpOnly cookie",
      "mfa": "None"
    }
  },
  "contracts": {
    "dtos": [],
    "endpoints": [
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/register",
        "protocol": "REST",
        "auth_required": "No",
        "http_method": "POST"
      },
      {
        "service_unit": "auth-api",
        "name_path": "/api/v1/auth/login",
        "protocol": "REST",
        "auth_required": "No",
        "http_method": "POST"
      }
    ],
    "versioning": {
      "strategy": "URL path (/v1/)",
      "current_version": "v1"
    }
  },
  "frontend": {
    "tech": {
      "language": "TypeScript",
      "platform": "Web",
      "framework": "React",
      "meta_framework": "Next.js",
      "package_manager": "npm",
      "styling": "Tailwind CSS"
    },
    "pages": [
      {
        "name": "Register",
        "route": "/register",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit registration form with email and password",
        "loading": "Spinner",
        "error_handling": "Inline form errors and Toast"
      },
      {
        "name": "Login",
        "route": "/login",
        "auth_required": "No",
        "layout": "AuthLayout",
        "core_actions": "Submit login credentials",
        "loading": "Spinner",
        "error_handling": "Inline form errors and Toast"
      }
    ]
  }
}
